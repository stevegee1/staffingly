# Database
DATABASE_URL="postgresql://user:password@localhost:5432/staffverify?schema=public"

# Server
PORT=3011
NODE_ENV=development

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3010

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Stripe (for billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Availity (for eligibility checks)
AVAILITY_CLIENT_ID=your-availity-client-id
AVAILITY_CLIENT_SECRET=your-availity-client-secret

# Internal API (for automation webhooks)
INTERNAL_API_TOKEN=your-internal-api-token

# Cron Jobs
CRON_SECRET=your-cron-secret-key

# Email (optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password

# File Storage (optional, for cloud storage)
# If not configured, local file storage will be used for development
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=staffverify-uploads
AWS_S3_REGION=us-east-1

# OCR / AI (optional)
OPENAI_API_KEY=sk-...
OCR_SPACE_API_KEY=your-ocr-space-api-key
GOOGLE_CLOUD_VISION_API_KEY=your-google-cloud-vision-api-key

# Azure AI Document Intelligence (optional, for insurance card OCR)
# Staff can choose OCR.space, Google Cloud Vision, or Azure in the upload flow.
# If none of these are configured, insurance card extraction will fail instead of returning mock data.
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-key
