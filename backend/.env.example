# Database
DATABASE_URL="postgresql://user:password@localhost:5432/staffverify?schema=public"

# Server
PORT=3011
NODE_ENV=development

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3010

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Stripe (for billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Availity (for eligibility checks)
AVAILITY_API_KEY=your-availity-api-key
AVAILITY_API_SECRET=your-availity-api-secret

# Internal API (for automation webhooks)
INTERNAL_API_TOKEN=your-internal-api-token

# Cron Jobs
CRON_SECRET=your-cron-secret-key

# Email (optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password

# File Storage (optional, for cloud storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=staffverify-uploads
AWS_REGION=us-east-1

# LLM/AI (optional, for document extraction)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
